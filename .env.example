# Copie para `.env` e preencha. Não comite `.env`.
# Variáveis obrigatórias (sem predefinição no código) estão assinaladas.
#
# -- Aplicação (IAC_*) --
# Obrigatórias: IAC_DATABASE_URL, IAC_JWT_SECRET
# Opcionais com predefinição em Settings: IAC_APP_NAME, IAC_DEBUG, algoritmo JWT, TTLs, limites de listagem, etc.

# Obrigatório: URL do SQLAlchemy
IAC_DATABASE_URL=postgresql+psycopg://CHANGE_ME:CHANGE_ME@localhost:5432/CHANGE_ME

# Obrigatório: segredo para assinatura JWT (use valor aleatório longo; não reutilize em produção)
IAC_JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Facultativo (não sensível)
IAC_APP_NAME=identity-access-service
IAC_DEBUG=false

# JWT e sessão (facultativos; ver Settings para predefinições e intervalos)
# IAC_JWT_ALGORITHM=HS256
# IAC_ACCESS_TOKEN_EXPIRE_MINUTES=15
# IAC_REFRESH_TOKEN_EXPIRE_DAYS=7
# IAC_MIN_PASSWORD_LENGTH=8
# IAC_MAX_NAME_LENGTH=255
# IAC_LIST_DEFAULT_LIMIT=100
# IAC_LIST_MAX_LIMIT=500
# IAC_LIST_MAX_SKIP=1000000

# -- Docker Compose: PostgreSQL local (necessário se usar `docker compose` com o serviço `db`) --
# As credenciais devem coincidir com o que está em IAC_DATABASE_URL (host `db` dentro da stack).
IAC_DB_USER=CHANGE_ME
IAC_DB_PASSWORD=CHANGE_ME
IAC_DB_NAME=CHANGE_ME
